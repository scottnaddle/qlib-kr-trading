# ═══════════════════════════════════════════════════════════════
# 환경변수 설정 파일
# 이 파일을 복사해서 .env 로 저장 후 실제 값을 입력하세요
# cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── 한국투자증권 KIS Developers API ──────────────────────────
# https://apiportal.koreainvestment.com/ 에서 발급
KIS_APP_KEY=your_app_key_here
KIS_APP_SECRET=your_app_secret_here

# 계좌번호: 12345678-01 형식 (계좌번호-상품코드)
KIS_ACCOUNT_NO=12345678-01

# 모의투자: true / 실거래: false
KIS_MOCK=true

# ── 키움증권 Open API+ (Windows 전용) ────────────────────────
# 키움 HTS 로그인 아이디/비밀번호 (API 별도 설정 불필요)
# PyQt5 기반으로 자동 로그인 팝업이 뜸
KIWOOM_MOCK=true

# ── qlib 데이터 경로 ─────────────────────────────────────────
QLIB_DATA_DIR=~/.qlib/qlib_data

# ── 알림 설정 (선택) ─────────────────────────────────────────
# 텔레그램 봇으로 주문 체결 알림을 받을 수 있습니다
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
